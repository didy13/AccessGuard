# Copy to .env and fill in values before running the server.

# SQLite (default) — swap for postgresql+psycopg2://user:pass@host/db in production
DATABASE_URL=sqlite:///./accessguard.db

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=Sq-fCrXBr7DsLb0F3_LtZbJN84xR8NifjUnavPSRmcc=

# Global fallback API key (per-company key takes precedence)
AGENT_API_KEY=change-me-strong-agent-key

# Key required to access /api/v1/admin/* routes
ADMIN_API_KEY=change-me-strong-admin-key

# Set to false only during local development
AUTH_ENABLED=false
